# Copy this file to `deploy.env` (gitignored) and fill in your values.
# Then run:
#   aws-vault exec <profile> -- ./bootstrap.sh   # one-time infra setup
#   aws-vault exec <profile> -- ./deploy.sh      # every deploy

# S3 bucket that holds the static files (will be created by bootstrap.sh).
BUCKET=your-darts-bucket-name

# Region the bucket lives in.
REGION=eu-north-1

# The EXISTING CloudFront distribution to attach the origin/behavior to.
DISTRIBUTION_ID=E1234567890ABC

# How the app is served by the distribution:
#   empty      -> the app becomes the distribution's DEFAULT behavior (served at /)
#   /darts/*   -> the app is served under a path prefix (coexists with other content)
PATH_PATTERN=

# ---------------------------------------------------------------------------
# Power-scoring backend (infra/backend.sh). Optional — only needed for the
# in-app Log view that stores TEST sessions server-side (DynamoDB + Lambda).
# ---------------------------------------------------------------------------

# Bearer token you paste into the app once (Log tab). Treat it like a password.
# Generate one with:  openssl rand -hex 24
API_TOKEN=

# Secret CloudFront injects as the X-Origin-Secret header so the Lambda
# Function URL can't be hit directly, bypassing CloudFront. Generate with:
#   openssl rand -hex 24      (leave empty to disable this extra guard)
ORIGIN_SECRET=

# Resource names (defaults are fine; override only to avoid collisions).
TABLE_NAME=darts-practice
LAMBDA_NAME=darts-practice-api
LAMBDA_ROLE=darts-practice-api-role
